# Copy this file to ".env" and fill in the values. Never commit your real .env.

# 1) Get this from @BotFather on Telegram after creating a bot.
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# 2) Your own numeric Telegram user ID. Get it by messaging @userinfobot.
#    The bot will ONLY respond to this ID.
ALLOWED_USER_ID=000000000

# 3) Where the SQLite database file lives (default is fine for local use).
SQLITE_PATH=data/vault.db

# 4) Where uploaded files are stored (default is fine for local use).
STORAGE_PATH=data/files

# 5) Where backup zips are written.
BACKUP_PATH=data/backups

# Reserved for a future PostgreSQL upgrade. Leave blank for v1.
DATABASE_URL=

# 6) OPTIONAL: connect the book archive to Obsidian.
#    Set this to your Obsidian vault folder and the bot will write one Markdown
#    note per book into it. Leave blank to disable. Examples:
#      Windows:  OBSIDIAN_VAULT_PATH=C:\Users\You\Documents\MyVault
#      macOS:    OBSIDIAN_VAULT_PATH=/Users/you/Documents/MyVault
OBSIDIAN_VAULT_PATH=
# Sub-folder inside the vault for book notes (created automatically).
OBSIDIAN_BOOKS_SUBFOLDER=Books

# 7) OPTIONAL: where YouTube->MP3 downloads are posted.
#    Add this bot to your private channel as an ADMIN, then put the channel here.
#    Either a numeric id like -1001234567890, or a public @channelusername.
#    Leave blank to have the MP3 sent to your own chat instead.
MUSIC_CHANNEL_ID=
